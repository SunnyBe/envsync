# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://envsync:your_password@localhost:5433/envsync

# AES-256-GCM encryption key — must be exactly 64 hex characters (32 bytes).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENV_SYNC_SECRET=replace_with_64_hex_chars

# Server port (default 3001)
PORT=3001

# Comma-separated list of allowed CORS origins for the web dashboard
ALLOWED_ORIGINS=http://localhost:3000

# Secret for the internal health endpoint — any random string
HEALTH_SECRET=replace_with_a_random_string

# Secret for the Prometheus /metrics scrape endpoint (X-Metrics-Token header).
# If unset, the endpoint is open — set this in production.
METRICS_SECRET=replace_with_a_random_string
