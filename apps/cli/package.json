{
  "name": "envsync",
  "version": "1.0.0",
  "description": "Sync environment variables across your team — CLI tool",
  "license": "MIT",
  "private": false,
  "bin": {
    "envsync": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "env",
    "dotenv",
    "sync",
    "cli",
    "devops",
    "environment-variables"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
