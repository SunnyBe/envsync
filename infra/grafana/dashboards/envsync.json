{
  "title": "EnvSync API",
  "uid": "envsync-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "description": "RED: Rate — how many requests per second is the API handling?",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"envsync-backend\"}[5m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (4xx + 5xx req/s)",
      "type": "timeseries",
      "description": "RED: Errors — how many failing requests per second?",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"envsync-backend\", status_code=~\"4..|5..\"}[5m])) by (status_code, route)",
          "legendFormat": "{{status_code}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "title": "Request Duration Percentiles",
      "type": "timeseries",
      "description": "RED: Duration — p50 is typical, p95 is 'most users', p99 is worst-case tail latency.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app=\"envsync-backend\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{app=\"envsync-backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app=\"envsync-backend\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "description": "USE: Memory utilisation — rising heap over time can indicate a memory leak.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{app=\"envsync-backend\"}",
          "legendFormat": "Heap used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{app=\"envsync-backend\"}",
          "legendFormat": "Heap total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "description": "USE: Saturation — high event loop lag means the Node.js thread is too busy to process I/O promptly.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{app=\"envsync-backend\"}",
          "legendFormat": "Event loop lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false,
        "label": "Datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" }
}
